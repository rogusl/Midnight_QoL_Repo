# Change this to match your CURSEFORGE project slug, 
# but it must NOT be the same name as your subfolders if you use move-folders.
package-as: MidnightQoL_Suite

move-folders:
  MidnightQoL: MidnightQoL
  MidnightQoL_BuffAlerts: MidnightQoL_BuffAlerts
  MidnightQoL_Castbar: MidnightQoL_Castbar
  MidnightQoL_QoL: MidnightQoL_QoL
  MidnightQoL_ResourceBars: MidnightQoL_ResourceBars
  MidnightQoL_Whisper: MidnightQoL_Whisper

ignore:
  - .pkgmeta
  - .gitignore
  - .github
  - .git
  - bump_version.py
  - generate_manifests.py
  - generate_manifests.ps1
  - README.md