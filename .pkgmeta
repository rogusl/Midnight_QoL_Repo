# Change this to match your CURSEFORGE project slug, 
# but it must NOT be the same name as your subfolders if you use move-folders.
package-as: rog-ui

move-folders:
  MidnightQoL: MidnightQoL
  RogUI_Bags: RogUI_Bags
  RogUI_Bars: RogUI_Bars
  RogUI_Core: RogUI_Core
  RogUI_ImprovedCDM: RogUI_ImprovedCDM
  RogUI_Keystones: RogUI_Keystones
  RogUI_SmartSwap: RogUI_SmartSwap
  RogUI_Whisper: RogUI_Whisper

ignore:
  - .pkgmeta
  - .gitignore
  - .github
  - .git
  - bump_version.py
  - generate_manifests.py
  - generate_manifests.ps1
  - README.md